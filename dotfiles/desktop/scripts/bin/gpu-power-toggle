#!/bin/bash

TDP_UNDERVOLT=300
TDP_NORMAL=450

get_current_tdp() {
    nvidia-smi --query-gpu=power.limit --format=csv,noheader,nounits | awk '{print int($1)}'
}

get_status() {
    current=$(get_current_tdp)
    if [ "$current" -le "$TDP_UNDERVOLT" ]; then
        echo "undervolt"
    else
        echo "normal"
    fi
}

toggle() {
    current_status=$(get_status)
    if [ "$current_status" = "undervolt" ]; then
        pkexec nvidia-smi -pl $TDP_NORMAL
        notify-send -u low -t 2000 "GPU Power" "TDP: ${TDP_NORMAL}W (Normal)"
    else
        pkexec nvidia-smi -pl $TDP_UNDERVOLT
        notify-send -u low -t 2000 "GPU Power" "TDP: ${TDP_UNDERVOLT}W (Undervolt)"
    fi
}

case "${1:-status}" in
    toggle) toggle ;;
    status)
        current=$(get_current_tdp)
        if [ "$current" -le "$TDP_UNDERVOLT" ]; then
            echo "{\"text\": \"󰡧\", \"tooltip\": \"GPU: ${current}W (Undervolt)\"}"
        else
            echo "{\"text\": \"󰡨\", \"tooltip\": \"GPU: ${current}W (Normal)\"}"
        fi
        ;;
esac
